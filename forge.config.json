{
  "orgs": ["your-org", "your-username"],

  "essentials": [
    "banner_logo", "badges", "toc", "features_sec", "tech_stack",
    "install", "usage", "code_blocks", "roadmap", "contributing", "license_sec"
  ],

  "include_forks": false,
  "include_archived": false,

  "exclude_names": [".github"],
  "exclude_suffixes": ["-backup"],
  "exclude_regex": [],

  "workdir": ".forge",
  "commit_prefix": "docs:",
  "max_workers": 10,

  "grace_days": 30,
  "ignore_topic": "forge-ignore",
  "max_prs": 10,
  "pr_branch": "forge/harmonize",
  "report_label": "forge-report"
}
